# Copie para a raiz do projeto e preencha o token:
#   cp .env.example .env
#
# Token (escopo mínimo típico: public_repo / leitura de repositórios públicos)
# https://github.com/settings/tokens

# Obrigatório para a API (sem aspas)
GITHUB_TOKEN=

# Caminhos e nomes de saída
DATA_DIR=./data
OUTPUT_CSV=pull_requests_data.csv
REPOSITORIES_CSV=selected_repositories.csv
LOG_FILE=./data/crawler.log

# Número de requisições em paralelo ao processar PRs (1–32 típico; 403=reduzir)
GITHUB_CONCURRENCY=16
